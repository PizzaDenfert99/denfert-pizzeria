# Customer app — runtime configuration.
#
# The customer app (denfert-pizzeria) MUST talk to the shared backend that
# also powers the loyalty/POS tablet app (pizza-denfert-loyalty/backend on the
# Hetzner VPS). Same backend → same MongoDB → same reservations, menu, loyalty
# points, customer accounts across both apps.
#
# The URL below resolves to the FastAPI service deployed at the loyalty
# subdomain. The customer app calls it via /api/* paths — CORS is open on
# that backend so cross-origin calls from pizzadenfert.fr (customer domain)
# are accepted.
EXPO_PUBLIC_BACKEND_URL=https://loyalty.pizzadenfert.fr
