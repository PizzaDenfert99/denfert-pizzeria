# Customer app — example environment configuration.
#
# Copy to .env and adjust for your environment. The customer app talks to the
# SHARED backend that also powers the loyalty/POS tablet app (one backend,
# one MongoDB, one source of truth).
#
# Production:
EXPO_PUBLIC_BACKEND_URL=https://loyalty.pizzadenfert.fr

# Local dev (uncomment when running the loyalty backend locally):
# EXPO_PUBLIC_BACKEND_URL=http://localhost:8001
